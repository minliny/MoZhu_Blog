# =============================================
# Notion 同步配置（必需）
# =============================================

# Notion Integration Token
# 获取方式：
# 1. 打开 https://www.notion.so/my-integrations
# 2. 新建一个 Internal Integration
# 3. 复制生成的 Token，格式如：secret_xxxxxxxxxxxx
NOTION_TOKEN=

# Notion 数据库 ID
# 获取方式：
# 1. 打开你的文章数据库页面
# 2. 从 URL 中复制数据库 ID（介于最后一个 / 和 ? 之间的 32 位字符串）
# 或在新版 Notion 中，直接从数据库页面的 URL 末尾获取
NOTION_DATABASE_ID=

# =============================================
# 站点配置（必需）
# =============================================

# 站点根 URL，末尾不带斜杠
# 当前仓库示例：https://minliny.github.io/MoZhu_Blog
# 用于生成 RSS 中的文章链接和 absolute path
SITE_URL=https://minliny.github.io/MoZhu_Blog

# =============================================
# 可选同步行为配置
# =============================================

# 允许 Notion 数据库为空时继续同步（默认关闭）
ALLOW_EMPTY_NOTION_SYNC=

# 设为 1 时，不删除本地已不存在于 Notion 发布列表中的文章
DISABLE_NOTION_SYNC_DELETE=

# 仅在你自行扩展 GitHub API 调用时使用
GITHUB_TOKEN=
